<UserControl x:Class="Games_Launcher.Views.MoveGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Games_Launcher.Views"
             mc:Ignorable="d" 
             Width="750">
	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="100"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<StackPanel Orientation="Horizontal" Margin="10">
			<Image d:Source="/Img/ErrorImg.png" Source="{Binding Icon}" Margin="30, 7.5, 7.5, 7.5"/>
			<TextBlock Style="{StaticResource TBK}" Text="{Binding Name}" d:Text="GAME TITLE"
				       TextAlignment="Center" Foreground="White" TextWrapping="Wrap" FontSize="20"
					   Width="172" Margin="0,0,0,25"/>

			<StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="9,0,5,0">
				<StackPanel.LayoutTransform>
					<ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
				</StackPanel.LayoutTransform>
				<Label Style="{StaticResource lblSNTNBG}" VerticalAlignment="Top" Padding="2, 0"
					   FontSize="13" Foreground="White" Content="TIEMPO DE JUEGO"/>

				<Label x:Name="LBLTimeOppend" Style="{StaticResource lblSNTNBG}"
					   VerticalAlignment="Top" FontSize="13" Padding="3, 0"
					   d:Content="100,0 minutos" Content="{Binding PlayTimeFormatted}"/>
			</StackPanel>
			<StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right"
						Margin="22.3,0,0,0" Visibility="Visible">
				<StackPanel.LayoutTransform>
					<ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
				</StackPanel.LayoutTransform>

				<Label Style="{StaticResource lblSNTNBG}" VerticalAlignment="Top"
					   Padding="2, 0" FontSize="13" Foreground="White" Content="ULTIMA VEZ JUGADO"/>

				<Label x:Name="LBLLastOppend" Style="{StaticResource lblSNTNBG}"
					   VerticalAlignment="Top" FontSize="13" Padding="3, 0" MaxWidth="125"
					   d:Content="00/00/0000" Content="{Binding LastPlayedFormatted}"/>
			</StackPanel>
		</StackPanel>


		<StackPanel Orientation="Vertical" Margin="5, 0" Grid.Row="1">
		<TextBlock Style="{StaticResource TBK}"
				   d:Text="D:\SteamLibrary\steamapps\common\Borderlands 2\Binaries\Win32\Borderlands2.exe"
				   VerticalAlignment="Bottom" Text="{Binding Path}" Margin="0,0,0,0" MaxWidth="700" TextWrapping="Wrap"/>
			<StackPanel Margin="10">
				<Label HorizontalAlignment="Left" FontSize="17" Style="{StaticResource lblSNTNBG}" Content="Ruta raiz del juego:"/>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="26"/>
					</Grid.ColumnDefinitions>
					<Button Grid.Column="1" ToolTip="Seleccionar archivo del juego"
							Padding="0" FontSize="15" Height="26" Width="26"
							x:Name="SelectGameRootPathBTN" Style="{StaticResource ButtonStyle}"
							Content="📁" VerticalAlignment="Bottom" Click="SelectGameRootPathBTN_Click"/>

					<TextBox x:Name="RootPathTBX" FontSize="17" Style="{StaticResource TBX}" HorizontalAlignment="Stretch"/>
				</Grid>
			</StackPanel>
			<StackPanel Margin="10">
				<Label HorizontalAlignment="Left" FontSize="17" Style="{StaticResource lblSNTNBG}" Content="Carpeta para mover el juego:"/>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="26"/>
					</Grid.ColumnDefinitions>
					<Button Grid.Column="1" ToolTip="Seleccionar archivo del juego"
							Padding="0" FontSize="15" Height="26" Width="26"
							x:Name="SelectGameMovePathBTN" Style="{StaticResource ButtonStyle}"
							Content="📁" VerticalAlignment="Top" Click="SelectGameMovePathBTN_Click"/>

					<TextBox x:Name="MovePathTBX" FontSize="17" Style="{StaticResource TBX}" HorizontalAlignment="Stretch"/>
				</Grid>
			</StackPanel>

			<StackPanel Margin="12" HorizontalAlignment="Center" Orientation="Horizontal">
				<Button x:Name="MoverBTN"
						Style="{StaticResource ButtonStyle}"
						Content="Mover"
						FontSize="17"
						Margin="30, 0" Click="MoverBTN_Click"/>
				<Button x:Name="CancelarBTN"
						Style="{StaticResource ButtonStyle}"
						Content="Cancelar"
						Margin="30, 0"
						FontSize="17" Click="CancelarBTN_Click"/>
			</StackPanel>

			<Border x:Name="bprgbr" Visibility="Visible" BorderBrush="#333" HorizontalAlignment="Stretch"
					Padding="1" BorderThickness="4" Margin="50,10">
				<ProgressBar x:Name="prgbr"
							 Minimum="0" Maximum="100" Value="0"
							 Height="20" Background="#333"
							 BorderThickness="0" BorderBrush="#333"/>
			</Border>

			<TextBlock x:Name="ProgressTextBlock" Style="{StaticResource TBK}"
					   FontSize="16" TextAlignment="Center" Visibility="Collapsed"
					   Margin="0,5,0,0" Text="Moviendo . . ." TextWrapping="Wrap"/>
		</StackPanel>
	</Grid>
</UserControl>
