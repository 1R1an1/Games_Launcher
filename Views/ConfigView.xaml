<UserControl x:Class="Games_Launcher.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Games_Launcher.Views"
             mc:Ignorable="d" 
             Height="399" Width="330">
    <StackPanel Orientation="Vertical">
		<StackPanel Orientation="Vertical" Margin="0,10"
					HorizontalAlignment="Center">
			<Label Style="{StaticResource lblSNTNBG}"
				   Content="Iniciar con windows"
				   Margin="0,0,0,7.5"
				   FontSize="14"
				   Foreground="#aaa"/>
			<CheckBox x:Name="CBStartWindows" Style="{StaticResource checkBox}" Unchecked="CBStartWindows_Unchecked" Checked="CBStartWindows_Checked"/>
		</StackPanel>

		<Button Style="{StaticResource ButtonStyle}"
				Margin="0,20"
				Padding="8,5"
				FontSize="14"
				x:Name="BTNStartMenu"
				Content="Agregar app a menu inicio" Click="BTNStartMenu_Click"/>
	</StackPanel>
</UserControl>
